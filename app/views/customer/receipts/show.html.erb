<div class="min-h-screen" style="background-color: var(--miam-bg); color: var(--miam-text);">
  <div class="mx-auto max-w-lg px-4 py-8">
    <%# Header %>
    <div class="text-center mb-8">
      <% if @theme["logoUrl"].present? %>
        <img src="<%= @theme["logoUrl"] %>" alt="<%= @restaurant.name %>" class="mx-auto mb-3 h-12 max-w-16 object-contain">
      <% end %>
      <div class="mx-auto mb-3 flex h-16 w-16 items-center justify-center rounded-full bg-green-500 text-white">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="text-2xl font-bold">Thank you!</h1>
      <p class="text-sm opacity-50 mt-1">Your bill at <%= @restaurant.name %> has been paid</p>
    </div>

    <%# Items %>
    <div class="rounded-2xl p-5 mb-4" style="background-color: <%= @theme['textColor'] %>05">
      <p class="text-xs font-semibold uppercase tracking-wide opacity-40 mb-3">Items</p>
      <div class="space-y-2">
        <% @order_items.each do |item| %>
          <% unit = item.price.to_f + (item.variant_price_modifier || 0).to_f %>
          <% qty = item.quantity || 1 %>
          <% line_total = unit * qty %>
          <div class="flex items-center justify-between text-sm">
            <div class="flex-1">
              <span><%= item.name %></span>
              <% if qty > 1 %>
                <span class="opacity-40 ml-1.5"><%= qty %> &times; <%= number_to_currency(unit, unit: "€", format: "%u%n") %></span>
              <% end %>
            </div>
            <span class="font-medium ml-4"><%= number_to_currency(line_total, unit: "€", format: "%u%n") %></span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Totals %>
    <div class="rounded-2xl p-5 mb-4" style="background-color: <%= @theme['textColor'] %>05">
      <div class="flex justify-between text-sm">
        <span class="opacity-60">Subtotal</span>
        <span><%= number_to_currency(@order.total_amount, unit: "€", format: "%u%n") %></span>
      </div>
      <% if @tip_total > 0 %>
        <div class="flex justify-between text-sm mt-1">
          <span class="opacity-60">Tip</span>
          <span><%= number_to_currency(@tip_total, unit: "€", format: "%u%n") %></span>
        </div>
      <% end %>
      <div class="flex justify-between mt-2 pt-2" style="border-top: 1px solid <%= @theme['textColor'] %>15">
        <span class="text-lg font-bold">Total paid</span>
        <span class="text-lg font-bold text-green-600"><%= number_to_currency(@paid_amount + @tip_total, unit: "€", format: "%u%n") %></span>
      </div>
    </div>

    <%# Payments breakdown %>
    <% if @payments.size > 1 %>
      <div class="rounded-2xl p-5 mb-4" style="background-color: <%= @theme['textColor'] %>05">
        <p class="text-xs font-semibold uppercase tracking-wide opacity-40 mb-3">Payments</p>
        <div class="space-y-1.5">
          <% @payments.each_with_index do |payment, idx| %>
            <div class="flex justify-between text-sm">
              <span class="opacity-60">Payment <%= idx + 1 %></span>
              <span><%= number_to_currency(payment.amount.to_f + (payment.tip_amount || 0).to_f, unit: "€", format: "%u%n") %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Review section %>
    <% if @review.nil? %>
      <div class="rounded-2xl p-5 text-center" style="background-color: <%= @theme['textColor'] %>05"
        data-controller="review-stars"
        data-review-stars-restaurant-id-value="<%= @restaurant.id %>"
        data-review-stars-order-id-value="<%= @order.id %>"
        data-review-stars-google-url-value="<%= @restaurant.google_business_url %>">
        <p class="text-sm opacity-60 mb-3">How was your experience at <%= @restaurant.name %>?</p>
        <div class="flex justify-center gap-2" data-review-stars-target="stars">
          <% 5.times do |i| %>
            <button data-action="click->review-stars#rate" data-review-stars-value-param="<%= i + 1 %>"
              class="transition-transform hover:scale-110">
              <svg class="h-10 w-10 text-gray-300" data-review-stars-target="star" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </button>
          <% end %>
        </div>

        <div data-review-stars-target="feedbackSection" class="hidden mt-4">
          <p class="text-sm opacity-50 mb-2">What could we improve?</p>
          <textarea data-review-stars-target="feedback" placeholder="Your feedback helps us improve..." rows="3"
            class="w-full rounded-xl border px-4 py-2.5 text-sm outline-none"
            style="border-color: <%= @theme['textColor'] %>20"></textarea>
        </div>

        <div data-review-stars-target="submitSection" class="hidden mt-4">
          <button data-action="click->review-stars#submit"
            class="w-full rounded-2xl py-3 text-center font-semibold text-white"
            style="background-color: <%= @theme['primaryColor'] %>"
            data-review-stars-target="submitButton">
            Submit feedback
          </button>
        </div>
      </div>
    <% else %>
      <div class="rounded-2xl p-5 text-center" style="background-color: <%= @theme['textColor'] %>05">
        <p class="font-semibold text-green-600">Thanks for your feedback!</p>
      </div>
    <% end %>

    <p class="text-center text-xs opacity-30 mt-8">Powered by Miam</p>
  </div>
</div>
