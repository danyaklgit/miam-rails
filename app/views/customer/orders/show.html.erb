<%= turbo_stream_from "order_#{@order.id}" %>

<%# Signal element — replaced by Turbo Stream when order status changes, triggers page refresh %>
<div data-controller="order-tracking">
  <div id="order_status_signal" data-status="<%= @order.status %>" data-total="<%= @order.total_amount %>" data-paid="<%= @order.paid_amount %>"></div>
</div>

<div class="min-h-screen bg-gray-50 pb-8">
  <%# Header %>
  <div class="bg-white px-4 pb-5 pt-6 shadow-sm">
    <div class="mx-auto max-w-lg">
      <%= link_to restaurant_path(slug: @restaurant.slug), class: "mb-3 inline-block text-sm font-medium text-gray-500 hover:text-gray-700" do %>
        &larr; Back to restaurant
      <% end %>
      <h1 class="text-xl font-bold text-gray-900">Order tracking</h1>
      <div class="mt-2 flex items-center gap-2">
        <span class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-bold uppercase
          <%= @is_delivery ? 'bg-blue-100 text-blue-800' : 'bg-amber-100 text-amber-800' %>">
          <%= @is_delivery ? "Delivery" : "Takeaway" %>
        </span>
        <span class="text-xs text-gray-400">#<%= @order.id.to_s[0, 8] %></span>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-lg px-4 py-6 space-y-6">
    <%# Ready banner %>
    <% if @order.status.in?(%w[ready completed]) %>
      <div class="rounded-2xl bg-green-50 border border-green-200 p-5 text-center">
        <div class="mx-auto mb-2 flex h-12 w-12 items-center justify-center rounded-full bg-green-500 text-white">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h2 class="text-lg font-bold text-green-800">
          <% if @order.status == "completed" %>
            Order completed!
          <% elsif @is_delivery %>
            Your order is on its way!
          <% else %>
            Your order is ready!
          <% end %>
        </h2>
        <p class="mt-1 text-sm text-green-600">
          <% if @order.status == "completed" %>
            Thank you for your order.
          <% elsif @is_delivery %>
            Your delivery is on the way to you.
          <% else %>
            Head to the counter to pick it up.
          <% end %>
        </p>
      </div>
    <% end %>

    <%# Status stepper %>
    <div id="order_status" class="rounded-2xl bg-white p-5 shadow-sm">
      <h3 class="mb-4 text-sm font-bold uppercase tracking-wide text-gray-400">Order status</h3>
      <div class="relative">
        <% @steps.each_with_index do |step, index| %>
          <% is_completed = index <= @current_step_index %>
          <% is_current = index == @current_step_index %>
          <% is_last = index == @steps.length - 1 %>
          <div class="flex items-start gap-4">
            <div class="flex flex-col items-center">
              <div class="flex h-9 w-9 items-center justify-center rounded-full transition-colors
                <%= is_completed ? 'bg-green-500 text-white' : 'border-2 border-gray-200 bg-white text-gray-300' %>
                <%= is_current && !is_completed ? 'border-amber-400 text-amber-500' : '' %>">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <% unless is_last %>
                <div class="h-8 w-0.5 <%= index < @current_step_index ? 'bg-green-500' : 'bg-gray-200' %>"></div>
              <% end %>
            </div>
            <div class="<%= is_last ? 'pb-0' : 'pb-6' %>">
              <p class="text-sm font-semibold <%= is_completed || is_current ? 'text-gray-900' : 'text-gray-400' %>">
                <%= step[:label] %>
              </p>
              <% if is_current && !@order.status.in?(%w[ready completed]) %>
                <p class="mt-0.5 text-xs text-amber-600">In progress...</p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Pickup time or delivery address %>
    <% if !@is_delivery && @order.pickup_time.present? %>
      <div class="rounded-2xl bg-white p-5 shadow-sm">
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-gray-900">Estimated pickup</p>
            <p class="text-sm text-gray-500"><%= @order.pickup_time.strftime("%H:%M") %></p>
          </div>
        </div>
      </div>
    <% end %>

    <% if @is_delivery && @order.delivery_address.present? %>
      <% addr = @order.delivery_address %>
      <div class="rounded-2xl bg-white p-5 shadow-sm">
        <div class="flex items-start gap-3">
          <svg class="mt-0.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-gray-900">Delivery address</p>
            <p class="text-sm text-gray-500"><%= addr["street"] %>, <%= addr["city"] %> <%= addr["postalCode"] %></p>
            <% if addr["instructions"].present? %>
              <p class="mt-1 text-xs italic text-gray-400"><%= addr["instructions"] %></p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Items %>
    <div class="rounded-2xl bg-white p-5 shadow-sm">
      <h3 class="mb-3 text-sm font-bold uppercase tracking-wide text-gray-400">Items</h3>
      <div class="space-y-3">
        <% @order_items.each do |item| %>
          <% item_total = (item.price.to_f + (item.variant_price_modifier || 0).to_f) * (item.quantity || 1) %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-gray-100 text-xs font-bold text-gray-600"><%= item.quantity %></span>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= item.name %></p>
                <% if item.variant_name.present? %>
                  <p class="text-xs text-gray-400"><%= item.variant_name %></p>
                <% end %>
              </div>
            </div>
            <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(item_total, unit: "€", format: "%u%n") %></p>
          </div>
        <% end %>
      </div>
      <div class="mt-4 border-t border-gray-100 pt-3">
        <div class="flex justify-between">
          <span class="font-bold text-gray-900">Total</span>
          <span class="font-bold text-gray-900"><%= number_to_currency(@order.total_amount, unit: "€", format: "%u%n") %></span>
        </div>
      </div>
    </div>
  </div>
</div>
