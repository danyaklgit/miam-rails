<!DOCTYPE html>
<html>
  <head>
    <title>Admin — Miam</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="min-h-screen bg-gray-50">
    <div class="flex">
      <%# Admin sidebar %>
      <aside class="fixed inset-y-0 left-0 w-16 bg-white border-r border-gray-200 flex flex-col items-center py-4 z-50">
        <div class="mb-8">
          <span class="text-xl font-bold text-red-500">M</span>
        </div>

        <nav class="flex-1 flex flex-col items-center gap-2">
          <%= link_to admin_path, class: "p-3 rounded-xl hover:bg-gray-100 transition-colors", title: "Overview" do %>
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          <% end %>
          <%= link_to admin_restaurants_path, class: "p-3 rounded-xl hover:bg-gray-100 transition-colors", title: "Restaurants" do %>
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <% end %>
          <%= link_to admin_analytics_path, class: "p-3 rounded-xl hover:bg-gray-100 transition-colors", title: "Analytics" do %>
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          <% end %>
        </nav>
      </aside>

      <%# Main content %>
      <main class="ml-16 flex-1 p-6">
        <% if flash[:notice] %>
          <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= flash[:alert] %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
