<!DOCTYPE html>
<html>
  <head>
    <title>Display — Miam</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="min-h-screen bg-gray-900 text-white">
    <%= turbo_stream_from "restaurant_#{@restaurant.id}" if @restaurant %>

    <% if flash[:notice] %>
      <div class="fixed top-4 right-4 z-50 p-4 bg-green-800 border border-green-600 rounded-lg text-green-100"><%= flash[:notice] %></div>
    <% end %>
    <%= yield %>
  </body>
</html>
