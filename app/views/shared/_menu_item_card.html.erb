<%# locals: (item:, restaurant:) %>
<% theme = restaurant.theme || {} %>
<% images = item.images || [] %>
<% text_color = theme['textColor'] || '#1f2937' %>
<% primary_color = theme['primaryColor'] || '#000000' %>

<button class="flex w-full gap-4 rounded-2xl border p-4 text-left transition-shadow hover:shadow-md"
  style="border-color: <%= text_color %>15"
  data-controller="item-modal"
  data-action="click->item-modal#open"
  data-item-modal-item-value="<%= item.to_json %>">
  <div class="min-w-0 flex-1">
    <h3 class="font-semibold"><%= item.name %></h3>
    <% if item.description.present? %>
      <p class="mt-1 line-clamp-2 text-sm opacity-60"><%= item.description %></p>
    <% end %>
    <% if (item.allergens || []).any? %>
      <div class="mt-2 flex flex-wrap gap-1">
        <% item.allergens.each do |allergen| %>
          <span class="rounded-full px-2 py-0.5 text-[10px] font-medium opacity-50"
            style="background-color: <%= text_color %>10"><%= allergen %></span>
        <% end %>
      </div>
    <% end %>
    <p class="mt-2 font-bold" style="color: <%= primary_color %>">
      <%= number_to_currency(item.price, unit: "€", format: "%u%n") %>
    </p>
  </div>
  <% if images.any? %>
    <img src="<%= images.first %>" alt="<%= item.name %>" class="h-24 w-24 shrink-0 rounded-xl object-cover">
  <% end %>
</button>
