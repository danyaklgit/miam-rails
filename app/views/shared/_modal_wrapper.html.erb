<%# locals: (id:, title:) %>
<div id="<%= id %>" class="fixed inset-0 z-50 hidden" data-modal-root data-controller="modal">
  <div class="absolute inset-0 bg-black/50" data-action="click->modal#close"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div data-modal-panel class="relative w-full max-w-lg rounded-2xl bg-white p-6 shadow-xl transition-all duration-150 scale-95 opacity-0">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900"><%= title %></h2>
        <button data-action="click->modal#close" class="rounded-full p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <%= yield %>
    </div>
  </div>
</div>
