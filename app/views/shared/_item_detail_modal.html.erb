<%# This modal is rendered empty and populated via Stimulus from item JSON data %>
<div id="item-detail-modal" class="fixed inset-0 z-50 hidden" data-controller="item-detail-modal">
  <%# Backdrop %>
  <div class="absolute inset-0 bg-black/50 transition-opacity" data-action="click->item-detail-modal#close"></div>

  <%# Bottom sheet %>
  <div class="absolute bottom-0 left-0 right-0 mx-auto max-w-lg rounded-t-3xl bg-white transition-transform duration-300 translate-y-full"
    style="max-height: 90vh; overflow-y: auto;"
    data-item-detail-modal-target="sheet">

    <%# Image gallery %>
    <div data-item-detail-modal-target="imageGallery" class="hidden relative">
      <div class="aspect-[4/3] overflow-hidden rounded-t-3xl bg-gray-100">
        <img data-item-detail-modal-target="mainImage" class="h-full w-full object-cover" src="" alt="">
      </div>
      <button data-action="click->item-detail-modal#close"
        class="absolute right-4 top-4 rounded-full bg-black/30 p-2 text-white backdrop-blur-sm">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <%# No image — close button in header %>
    <div data-item-detail-modal-target="noImageHeader" class="flex items-center justify-end p-4">
      <button data-action="click->item-detail-modal#close" class="rounded-full bg-gray-100 p-2">
        <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="px-5 pb-6">
      <%# Name + price %>
      <h2 data-item-detail-modal-target="name" class="text-xl font-bold"></h2>
      <p data-item-detail-modal-target="price" class="mt-1 text-lg font-bold"></p>

      <%# Description %>
      <p data-item-detail-modal-target="description" class="mt-3 text-sm opacity-60 hidden"></p>

      <%# Allergens %>
      <div data-item-detail-modal-target="allergens" class="mt-3 flex flex-wrap gap-1.5 hidden"></div>

      <%# Variants %>
      <div data-item-detail-modal-target="variantsSection" class="mt-4 hidden">
        <p class="mb-2 text-sm font-semibold">Options</p>
        <div data-item-detail-modal-target="variantsList" class="flex flex-wrap gap-2"></div>
      </div>

      <%# Notes %>
      <div class="mt-4">
        <textarea data-item-detail-modal-target="notes" placeholder="Special requests..." rows="2"
          class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400 resize-none"></textarea>
      </div>

      <%# Quantity + Add button %>
      <div class="mt-4 flex items-center gap-4">
        <div class="flex items-center rounded-xl border border-gray-200">
          <button data-action="click->item-detail-modal#decrement" class="px-3 py-2 text-lg font-bold text-gray-500 hover:text-gray-900">−</button>
          <span data-item-detail-modal-target="quantity" class="w-8 text-center text-sm font-semibold">1</span>
          <button data-action="click->item-detail-modal#increment" class="px-3 py-2 text-lg font-bold text-gray-500 hover:text-gray-900">+</button>
        </div>
        <button data-action="click->item-detail-modal#addToOrder"
          data-item-detail-modal-target="addButton"
          class="flex-1 rounded-xl py-3 text-center text-sm font-bold text-white transition-opacity hover:opacity-90">
          Add to order
        </button>
      </div>
    </div>
  </div>
</div>
