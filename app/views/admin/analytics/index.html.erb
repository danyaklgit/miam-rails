<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Platform Analytics</h1>
  <div class="flex gap-1 rounded-lg bg-gray-100 p-1">
    <% %w[24h 7d 30d 90d].each do |period| %>
      <%= link_to admin_analytics_path(period: period),
        class: "rounded-md px-3 py-1.5 text-sm font-medium transition-colors #{@period == period ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-700'}" do %>
        <%= period %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8">
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Orders</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_orders %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Revenue</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_to_currency(@total_revenue, unit: "€", format: "%u%n") %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Avg Order</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_to_currency(@avg_order_value, unit: "€", format: "%u%n") %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">New Restaurants</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @new_restaurants %></p>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Top Restaurants by Orders</h2>
    <div class="space-y-3">
      <% @orders_by_restaurant.each do |name, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600 truncate"><%= name %></span>
          <span class="text-sm font-semibold text-gray-900"><%= count %></span>
        </div>
      <% end %>
      <% if @orders_by_restaurant.empty? %>
        <p class="text-sm text-gray-400">No data</p>
      <% end %>
    </div>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Top Restaurants by Revenue</h2>
    <div class="space-y-3">
      <% @revenue_by_restaurant.each do |name, amount| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600 truncate"><%= name %></span>
          <span class="text-sm font-semibold text-gray-900"><%= number_to_currency(amount, unit: "€", format: "%u%n") %></span>
        </div>
      <% end %>
      <% if @revenue_by_restaurant.empty? %>
        <p class="text-sm text-gray-400">No data</p>
      <% end %>
    </div>
  </div>
</div>
