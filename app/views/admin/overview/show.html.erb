<h1 class="text-2xl font-bold text-gray-900 mb-6">Platform Overview</h1>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8">
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Total Restaurants</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_restaurants %></p>
    <p class="mt-1 text-xs text-green-600"><%= @active_restaurants %> active</p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Total Orders</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_orders %></p>
    <p class="mt-1 text-xs text-gray-400"><%= @orders_today %> today</p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Total Revenue</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_to_currency(@total_revenue, unit: "€", format: "%u%n") %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Total Users</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_users %></p>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Restaurants</h2>
<div class="rounded-2xl bg-white shadow-sm border border-gray-100 overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 text-left text-xs font-medium uppercase text-gray-500">
      <tr>
        <th class="px-6 py-3">Name</th>
        <th class="px-6 py-3">Slug</th>
        <th class="px-6 py-3">Status</th>
        <th class="px-6 py-3">Created</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @recent_restaurants.each do |r| %>
        <tr>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= r.name %></td>
          <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= r.slug %></td>
          <td class="px-6 py-4">
            <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= r.status == 'active' ? 'bg-green-100 text-green-800' : r.status == 'pending' ? 'bg-amber-100 text-amber-800' : 'bg-red-100 text-red-800' %>">
              <%= r.status %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= r.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4"><%= link_to "View", admin_restaurant_path(r), class: "text-sm font-medium text-red-600 hover:text-red-500" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
