<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900">miam</h1>
      <p class="mt-1 text-sm text-gray-500">Sign in to your dashboard</p>
    </div>

    <% if flash[:alert] %>
      <div class="mb-4 rounded-xl bg-red-50 border border-red-200 p-3 text-sm text-red-700"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="mb-4 rounded-xl bg-green-50 border border-green-200 p-3 text-sm text-green-700"><%= flash[:notice] %></div>
    <% end %>

    <div class="rounded-2xl bg-white p-8 shadow-sm border border-gray-100">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 outline-none focus:border-gray-400 focus:ring-1 focus:ring-gray-400" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 outline-none focus:border-gray-400 focus:ring-1 focus:ring-gray-400" %>
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300" %>
              <span class="text-sm text-gray-600">Remember me</span>
            </label>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm text-gray-500 hover:text-gray-700" %>
            <% end %>
          </div>

          <%= f.submit "Sign in",
            class: "w-full rounded-xl bg-gray-900 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <% if devise_mapping.registerable? %>
        <p class="mt-6 text-center text-sm text-gray-500">
          No account? <%= link_to "Sign up", new_registration_path(resource_name), class: "font-medium text-gray-900 hover:underline" %>
        </p>
      <% end %>
    </div>
  </div>
</div>
