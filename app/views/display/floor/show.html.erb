<%= turbo_stream_from "restaurant_#{@restaurant.id}" %>

<div class="min-h-screen bg-gray-900 p-4 sm:p-6" data-controller="auto-refresh floor-table"
  data-auto-refresh-interval-value="5000"
  data-auto-refresh-url-value="<%= request.path %>">

  <%# Header %>
  <header class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <h1 class="text-2xl font-bold text-white">Floor View</h1>
      <% occupied = @tables.count { |t| t[:session].present? } %>
      <span class="text-sm text-gray-400"><%= occupied %>/<%= @tables.size %> occupied</span>
    </div>
  </header>

  <%# Table grid %>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
    <% @tables.each do |data| %>
      <% table = data[:table] %>
      <% session = data[:session] %>
      <% order = data[:order] %>
      <% items = data[:items] %>
      <% counts = data[:item_counts] %>
      <% occupied = session.present? %>

      <button
        data-action="click->floor-table#select"
        data-floor-table-number-param="<%= table.number %>"
        class="rounded-xl border-2 p-4 transition-colors text-left
          <%= occupied ? 'border-orange-500 bg-orange-500/10' : 'border-gray-700 bg-gray-800/50 hover:border-gray-600' %>">

        <div class="flex items-center justify-between mb-2">
          <span class="text-2xl font-bold <%= occupied ? 'text-orange-400' : 'text-gray-500' %>">
            <%= table.number %>
          </span>
          <div class="h-2.5 w-2.5 rounded-full <%= occupied ? 'bg-orange-500' : 'bg-gray-600' %>"></div>
        </div>

        <p class="text-xs text-gray-500 mb-2"><%= table.capacity %> seats</p>

        <% if occupied %>
          <div class="space-y-1.5">
            <p class="text-xs text-gray-400">
              <%= data[:members].size %> <%= data[:members].size == 1 ? 'guest' : 'guests' %>
            </p>
            <div class="flex flex-wrap gap-1">
              <% if counts[:ordered] > 0 %>
                <span class="rounded-full bg-red-600/20 px-1.5 py-0.5 text-[10px] font-bold text-red-400"><%= counts[:ordered] %> new</span>
              <% end %>
              <% if counts[:preparing] > 0 %>
                <span class="rounded-full bg-yellow-600/20 px-1.5 py-0.5 text-[10px] font-bold text-yellow-400"><%= counts[:preparing] %> prep</span>
              <% end %>
              <% if counts[:ready] > 0 %>
                <span class="rounded-full bg-green-600/20 px-1.5 py-0.5 text-[10px] font-bold text-green-400"><%= counts[:ready] %> ready</span>
              <% end %>
            </div>
            <% if order %>
              <p class="text-sm font-bold text-white"><%= number_to_currency(order.total_amount, unit: "€", format: "%u%n") %></p>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-gray-600">Available</p>
        <% end %>
      </button>
    <% end %>
  </div>

  <%# Table detail panel (shown when a table is clicked) %>
  <div id="floor-table-detail" class="hidden mt-6">
    <%
      status_config = {
        "pending"   => { color: "#6b7280", label: "Pending" },
        "ordered"   => { color: "#ef4444", label: "Ordered" },
        "preparing" => { color: "#f59e0b", label: "Preparing" },
        "ready"     => { color: "#10b981", label: "Ready" },
        "served"    => { color: "#6b7280", label: "Served" }
      }
      next_status_map = { "pending" => "ordered", "ordered" => "preparing", "preparing" => "ready", "ready" => "served" }
      btn_colors = { "ordered" => "bg-red-600", "preparing" => "bg-yellow-600", "ready" => "bg-green-600", "served" => "bg-gray-600" }
      menus = @restaurant.menus.active.sorted.includes(categories: :menu_items)
    %>

    <% @tables.each do |data| %>
      <% table = data[:table] %>
      <% session = data[:session] %>
      <% order = data[:order] %>
      <% items = data[:items] %>
      <% occupied = session.present? %>
      <% pending_items = items.select { |i| i.status == "pending" } %>

      <div data-floor-table-target="panel" data-table-number="<%= table.number %>" class="hidden">
        <div class="rounded-xl border border-gray-700 bg-gray-800 p-5">
          <%# Header %>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-bold text-white">Table <%= table.number %></h2>
              <p class="text-xs text-gray-500"><%= table.capacity %> seats · <%= occupied ? "#{data[:members].size} guests" : "Available" %></p>
            </div>
            <div class="flex items-center gap-2">
              <% if occupied && session %>
                <button class="rounded-lg border border-red-600/30 bg-red-600/10 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-600/20 transition-colors"
                  onclick="if(confirm('Close session for Table <%= table.number %>? This will reset the table.')) { this.disabled=true; this.textContent='Closing...'; fetch('/api/sessions/<%= session.id %>/close', { method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content }}).then(() => location.reload()) }">
                  Close session
                </button>
              <% end %>
              <button data-action="click->floor-table#close" class="rounded-lg bg-gray-700 p-1.5 text-gray-400 hover:text-white transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          </div>

          <% if occupied && order %>
            <%# Summary row %>
            <div class="flex items-center gap-6 mb-4 rounded-lg bg-gray-900/50 px-4 py-3">
              <div class="text-center">
                <p class="text-lg font-bold text-white"><%= data[:members].size %></p>
                <p class="text-[10px] text-gray-500 uppercase">Guests</p>
              </div>
              <div class="text-center">
                <p class="text-lg font-bold text-white">€<%= order.total_amount.to_f.round(2) %></p>
                <p class="text-[10px] text-gray-500 uppercase">Bill</p>
              </div>
              <div class="text-center">
                <p class="text-lg font-bold text-white"><%= items.size %></p>
                <p class="text-[10px] text-gray-500 uppercase">Items</p>
              </div>
            </div>

            <%# Confirm pending items button %>
            <% if pending_items.any? %>
              <button class="w-full mb-4 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors"
                onclick="this.disabled=true; this.textContent='Confirming...'; fetch('/api/orders/<%= order.id %>/confirm', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content }}).then(() => location.reload())">
                Confirm <%= pending_items.size %> pending item<%= pending_items.size == 1 ? '' : 's' %>
              </button>
            <% end %>

            <%# Items grouped by status %>
            <% items.group_by(&:status).each do |status, group| %>
              <% cfg = status_config[status] || status_config["ordered"] %>
              <% ns = next_status_map[status] %>
              <% bulk_ids_json = group.map(&:id).to_json %>
              <div class="mb-3">
                <div class="flex items-center justify-between mb-2">
                  <p class="text-xs font-bold uppercase tracking-wide" style="color: <%= cfg[:color] %>"><%= cfg[:label] %> (<%= group.size %>)</p>
                  <% if ns && group.size > 1 %>
                    <%
                      bulk_label = case ns
                        when "ordered" then "Confirm all"
                        when "preparing" then "Prepare all"
                        when "ready" then "Ready all"
                        when "served" then "Serve all"
                        else "#{ns.capitalize} all"
                      end
                    %>
                    <button class="rounded-md px-2.5 py-1 text-[10px] font-bold text-white <%= btn_colors[ns] || 'bg-gray-600' %> hover:opacity-80 transition-opacity"
                      data-controller="bulk-status"
                      data-bulk-status-ids-value="<%= bulk_ids_json %>"
                      data-bulk-status-status-value="<%= ns %>"
                      data-bulk-status-table-num-value="<%= table.number %>"
                      data-action="click->bulk-status#update">
                      <%= bulk_label %>
                    </button>
                  <% end %>
                </div>
                <div class="space-y-1.5">
                  <% group.each do |item| %>
                    <div class="flex items-center justify-between rounded-lg p-2.5" style="border-left: 3px solid <%= cfg[:color] %>; background-color: <%= cfg[:color] %>10">
                      <div class="flex items-center gap-2 min-w-0 flex-1">
                        <span class="text-xs text-gray-500 shrink-0"><%= item.quantity %>&times;</span>
                        <span class="text-sm text-white truncate"><%= item.name %></span>
                        <% if item.variant_name.present? %>
                          <span class="text-xs text-gray-500 shrink-0"><%= item.variant_name %></span>
                        <% end %>
                        <% if item.notes.present? %>
                          <span class="text-xs italic text-yellow-400 truncate"><%= item.notes %></span>
                        <% end %>
                      </div>
                      <div class="flex items-center gap-2 shrink-0 ml-2">
                        <span class="text-xs text-gray-500">€<%= ((item.price.to_f + (item.variant_price_modifier || 0).to_f) * (item.quantity || 1)).round(2) %></span>
                        <% ns = next_status_map[status] %>
                        <% if ns %>
                          <button class="rounded-md px-2.5 py-1 text-[10px] font-bold text-white <%= btn_colors[ns] || 'bg-gray-600' %> hover:opacity-80 transition-opacity"
                            data-controller="ticket" data-ticket-item-id-value="<%= item.id %>" data-ticket-next-status-value="<%= ns %>"
                            data-action="click->ticket#advance">
                            → <%= ns.capitalize %>
                          </button>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%# Total %>
            <div class="mt-4 pt-3 border-t border-gray-700 flex items-center justify-between">
              <span class="text-sm text-gray-400">Total</span>
              <span class="text-lg font-bold text-white">€<%= order.total_amount.to_f.round(2) %></span>
            </div>

            <%# Add item (staff) %>
            <div class="mt-4 pt-3 border-t border-gray-700" data-controller="accordion">
              <button data-action="click->accordion#toggle" class="flex items-center gap-2 text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Add item (staff)
              </button>
              <div data-accordion-target="content" class="hidden mt-3 max-h-64 overflow-y-auto rounded-lg bg-gray-900 p-3">
                <% menus.each do |menu| %>
                  <% menu.categories.sorted.each do |cat| %>
                    <p class="text-[10px] font-bold uppercase tracking-wide text-gray-600 mt-2 mb-1"><%= cat.name %></p>
                    <% cat.menu_items.available.sorted.each do |mi| %>
                      <button class="flex w-full items-center justify-between rounded-md px-2 py-1.5 text-left hover:bg-gray-800 transition-colors"
                        onclick="this.disabled=true; this.querySelector('span:last-child').textContent='Adding...'; fetch('/api/orders/<%= order.id %>/items', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content }, body: JSON.stringify({ items: [{ menu_item_id: '<%= mi.id %>', name: '<%= j mi.name %>', price: '<%= mi.price %>', quantity: 1, type: '<%= mi.type %>', ordered_by: 'staff' }] }) }).then(() => location.reload())">
                        <span class="text-sm text-white"><%= mi.name %></span>
                        <span class="text-xs text-gray-500">€<%= mi.price.to_f.round(2) %></span>
                      </button>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            </div>

          <% elsif occupied %>
            <p class="text-sm text-gray-500 py-4">Session active, no order yet.</p>
          <% else %>
            <p class="text-sm text-gray-500 py-4">No active session on this table.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
