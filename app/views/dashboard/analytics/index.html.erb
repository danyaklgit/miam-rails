<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Analytics</h1>
  <div class="flex gap-1 rounded-lg bg-gray-100 p-1">
    <% %w[24h 7d 30d].each do |period| %>
      <%= link_to dashboard_analytics_path(period: period),
        class: "rounded-md px-3 py-1.5 text-sm font-medium transition-colors #{@period == period ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-700'}" do %>
        <%= period %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Stats %>
<div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-8">
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Total Orders</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_orders %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Revenue</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_to_currency(@total_revenue, unit: "€", format: "%u%n") %></p>
  </div>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <p class="text-sm font-medium text-gray-500">Avg Order Value</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_to_currency(@avg_order_value, unit: "€", format: "%u%n") %></p>
  </div>
</div>

<%# Breakdown %>
<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Orders by Type</h2>
    <div class="space-y-3">
      <% @orders_by_type.each do |type, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600"><%= type %></span>
          <div class="flex items-center gap-3">
            <div class="h-2 rounded-full bg-gray-100" style="width: 120px">
              <div class="h-2 rounded-full bg-gray-900" style="width: <%= @total_orders > 0 ? (count.to_f / @total_orders * 120).round : 0 %>px"></div>
            </div>
            <span class="text-sm font-semibold text-gray-900 w-8 text-right"><%= count %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Orders by Status</h2>
    <div class="space-y-3">
      <% @orders_by_status.each do |status, count| %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600"><%= status %></span>
          <div class="flex items-center gap-3">
            <div class="h-2 rounded-full bg-gray-100" style="width: 120px">
              <div class="h-2 rounded-full bg-gray-900" style="width: <%= @total_orders > 0 ? (count.to_f / @total_orders * 120).round : 0 %>px"></div>
            </div>
            <span class="text-sm font-semibold text-gray-900 w-8 text-right"><%= count %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
