<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
  <div class="flex gap-1 rounded-lg bg-gray-100 p-1">
    <% %w[current upcoming past all].each do |tab| %>
      <%= link_to dashboard_orders_path(tab: tab),
        class: "rounded-md px-3 py-1.5 text-sm font-medium transition-colors #{@tab == tab ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-700'}" do %>
        <%= tab.capitalize %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="rounded-2xl bg-white shadow-sm border border-gray-100 overflow-hidden">
  <% if @orders.any? %>
    <table class="w-full">
      <thead class="bg-gray-50 text-left text-xs font-medium uppercase text-gray-500">
        <tr>
          <th class="px-6 py-3">Order</th>
          <th class="px-6 py-3">Type</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3">Items</th>
          <th class="px-6 py-3">Amount</th>
          <th class="px-6 py-3">Time</th>
          <th class="px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @orders.each do |order| %>
          <tr>
            <td class="px-6 py-4 text-sm font-medium text-gray-900">#<%= order.id.to_s[0, 8] %></td>
            <td class="px-6 py-4">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= order.type == 'dineIn' ? 'bg-purple-100 text-purple-800' : order.type == 'delivery' ? 'bg-blue-100 text-blue-800' : 'bg-amber-100 text-amber-800' %>">
                <%= order.type %>
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= case order.status
                  when 'pending' then 'bg-gray-100 text-gray-800'
                  when 'confirmed' then 'bg-blue-100 text-blue-800'
                  when 'preparing' then 'bg-amber-100 text-amber-800'
                  when 'ready' then 'bg-green-100 text-green-800'
                  when 'completed' then 'bg-gray-100 text-gray-500'
                  else 'bg-red-100 text-red-800'
                end %>">
                <%= order.status %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= order.order_items.size %></td>
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= number_to_currency(order.total_amount, unit: "€", format: "%u%n") %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= time_ago_in_words(order.created_at) %> ago</td>
            <td class="px-6 py-4">
              <% unless order.status.in?(%w[completed cancelled]) %>
                <% next_status = { "pending" => "confirmed", "confirmed" => "preparing", "preparing" => "ready", "ready" => "completed" }[order.status] %>
                <% if next_status %>
                  <%= button_to next_status.capitalize, dashboard_order_path(order, status: next_status, tab: @tab), method: :patch,
                    class: "rounded-lg bg-gray-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-gray-800 transition-colors" %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-12 text-center text-gray-400">No orders</div>
  <% end %>
</div>
