<h1 class="text-2xl font-bold text-gray-900 mb-6">Theme Editor</h1>

<%= form_with url: dashboard_theme_path, method: :patch, class: "space-y-6" do %>
  <%# Branding Images %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100" data-controller="single-image-upload">
      <h2 class="text-lg font-semibold text-gray-900 mb-1">Cover Photo</h2>
      <p class="text-sm text-gray-500 mb-4">Full-screen background behind the restaurant name</p>
      <input type="file" accept="image/*" class="hidden" data-single-image-upload-target="input" data-action="change->single-image-upload#upload">
      <input type="hidden" name="theme[bannerImageUrl]" value="<%= (@restaurant.theme || {})['bannerImageUrl'] %>" data-single-image-upload-target="url">
      <div data-single-image-upload-target="preview"></div>
      <button type="button" data-action="click->single-image-upload#pick" data-single-image-upload-target="placeholder"
        class="flex h-32 w-full items-center justify-center rounded-xl border-2 border-dashed border-gray-300 text-gray-400 hover:border-gray-400 hover:text-gray-500 transition-colors">
        <div class="text-center">
          <svg class="mx-auto h-8 w-8 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <span class="text-xs font-medium">Upload cover photo</span>
        </div>
      </button>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100" data-controller="single-image-upload">
      <h2 class="text-lg font-semibold text-gray-900 mb-1">Logo</h2>
      <p class="text-sm text-gray-500 mb-4">Displayed over the cover photo on the landing page</p>
      <input type="file" accept="image/*" class="hidden" data-single-image-upload-target="input" data-action="change->single-image-upload#upload">
      <input type="hidden" name="theme[logoUrl]" value="<%= (@restaurant.theme || {})['logoUrl'] %>" data-single-image-upload-target="url">
      <div data-single-image-upload-target="preview"></div>
      <button type="button" data-action="click->single-image-upload#pick" data-single-image-upload-target="placeholder"
        class="flex h-32 w-full items-center justify-center rounded-xl border-2 border-dashed border-gray-300 text-gray-400 hover:border-gray-400 hover:text-gray-500 transition-colors">
        <div class="text-center">
          <svg class="mx-auto h-8 w-8 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <span class="text-xs font-medium">Upload logo</span>
        </div>
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <%# Colors %>
    <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Colors</h2>
      <div class="space-y-4">
        <% %w[primaryColor secondaryColor backgroundColor textColor].each do |key| %>
          <div class="flex items-center justify-between">
            <label class="text-sm font-medium text-gray-700"><%= key.underscore.humanize %></label>
            <div class="flex items-center gap-2">
              <input type="color" name="theme[<%= key %>]" value="<%= (@restaurant.theme || {})[key] || '#000000' %>"
                class="h-9 w-9 cursor-pointer rounded border border-gray-200">
              <input type="text" name="theme[<%= key %>]" value="<%= (@restaurant.theme || {})[key] || '#000000' %>"
                class="w-24 rounded-lg border border-gray-200 px-3 py-2 text-xs font-mono">
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Typography & Style %>
    <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Typography & Style</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Font Family</label>
          <select name="theme[fontFamily]" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm">
            <% %w[Inter Playfair\ Display Poppins Roboto Montserrat Lora].each do |font| %>
              <option value="<%= font %>" <%= 'selected' if (@restaurant.theme || {})['fontFamily'] == font %>><%= font %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Menu Style</label>
          <select name="theme[menuStyle]" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm">
            <% %w[cards list compact].each do |style| %>
              <option value="<%= style %>" <%= 'selected' if (@restaurant.theme || {})['menuStyle'] == style %>><%= style.capitalize %></option>
            <% end %>
          </select>
        </div>
      </div>
    </div>
  </div>

  <button type="submit" class="rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">
    Save theme
  </button>
<% end %>
