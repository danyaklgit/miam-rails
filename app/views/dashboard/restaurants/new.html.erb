<h1 class="text-2xl font-bold text-gray-900 mb-6">Create New Restaurant</h1>

<%= form_with model: [:dashboard, @new_restaurant], url: dashboard_restaurants_path, class: "max-w-lg space-y-6" do |f| %>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100 space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Restaurant Name</label>
      <%= f.text_field :name, placeholder: "My Restaurant", required: true,
        class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Slug (URL)</label>
      <%= f.text_field :slug, placeholder: "my-restaurant", required: true,
        class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      <p class="mt-1 text-xs text-gray-400">This will be your URL: miam.digital/<strong>your-slug</strong></p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <%= f.text_area :description, rows: 3, placeholder: "A short description of your restaurant",
        class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit "Create Restaurant", class: "rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", dashboard_path, class: "rounded-xl border border-gray-200 px-6 py-3 text-sm font-medium text-gray-600 hover:bg-gray-50" %>
  </div>
<% end %>
