<%# locals: (item:) %>
<%
  allergen_list = %w[gluten crustaceans eggs fish peanuts soybeans milk nuts celery mustard sesame sulphites lupin molluscs]
  item_allergens = item.allergens || []
%>
<%= render layout: "shared/modal_wrapper", locals: { id: "edit-item-modal-#{item.id}", title: "Edit Item" } do %>
  <%= form_with url: dashboard_menu_item_path(item), method: :patch, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
      <input type="text" name="menu_item[name]" value="<%= item.name %>" required
        class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-black focus:border-black">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <textarea name="menu_item[description]" rows="2"
        class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-black focus:border-black resize-none"><%= item.description %></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Price (€)</label>
      <input type="number" name="menu_item[price]" step="0.01" min="0" value="<%= item.price %>" required
        class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-black focus:border-black">
    </div>
    <div data-controller="image-upload">
      <label class="block text-sm font-medium text-gray-700 mb-1">Image</label>
      <input type="file" accept="image/*" class="hidden" data-image-upload-target="input" data-action="change->image-upload#upload">
      <input type="hidden" name="menu_item[images_json]" value="<%= (item.images || []).to_json %>" data-image-upload-target="urls">
      <div class="flex flex-wrap gap-2 items-center" data-image-upload-target="preview">
        <button type="button" data-action="click->image-upload#pick"
          class="flex h-20 w-20 shrink-0 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 text-gray-400 hover:border-gray-400 hover:text-gray-500 transition-colors">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        </button>
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Type</label>
      <div class="flex gap-2">
        <label class="flex-1 rounded-xl border-2 px-4 py-2.5 text-sm font-medium text-center cursor-pointer transition-colors has-[:checked]:border-black has-[:checked]:bg-black has-[:checked]:text-white border-gray-200">
          <input type="radio" name="menu_item[type]" value="food" <%= 'checked' if item.type == 'food' %> class="hidden">
          🍽 Food
        </label>
        <label class="flex-1 rounded-xl border-2 px-4 py-2.5 text-sm font-medium text-center cursor-pointer transition-colors has-[:checked]:border-black has-[:checked]:bg-black has-[:checked]:text-white border-gray-200">
          <input type="radio" name="menu_item[type]" value="drink" <%= 'checked' if item.type == 'drink' %> class="hidden">
          🍷 Drink
        </label>
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Allergens</label>
      <div class="flex flex-wrap gap-2">
        <% allergen_list.each do |allergen| %>
          <label class="rounded-full px-3 py-1 text-xs font-medium cursor-pointer transition-colors has-[:checked]:bg-red-100 has-[:checked]:text-red-800 has-[:checked]:ring-1 has-[:checked]:ring-red-300 bg-gray-100 text-gray-600">
            <input type="checkbox" name="menu_item[allergens][]" value="<%= allergen %>" <%= 'checked' if item_allergens.include?(allergen) %> class="hidden">
            <%= allergen %>
          </label>
        <% end %>
      </div>
    </div>
    <div class="flex gap-3 pt-2">
      <button type="submit" class="flex-1 rounded-xl bg-gray-900 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Save</button>
      <button type="button" data-action="click->modal#close" class="flex-1 rounded-xl border border-gray-200 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50">Cancel</button>
    </div>
  <% end %>
<% end %>
