<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Offers</h1>
  <%= link_to new_dashboard_offer_path, class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 transition-colors" do %>
    + New offer
  <% end %>
</div>

<div class="rounded-2xl bg-white shadow-sm border border-gray-100 overflow-hidden">
  <% if @offers.any? %>
    <table class="w-full">
      <thead class="bg-gray-50 text-left text-xs font-medium uppercase text-gray-500">
        <tr>
          <th class="px-6 py-3">Name</th>
          <th class="px-6 py-3">Type</th>
          <th class="px-6 py-3">Value</th>
          <th class="px-6 py-3">Code</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3">Redemptions</th>
          <th class="px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @offers.each do |offer| %>
          <tr>
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= offer.name %></td>
            <td class="px-6 py-4"><span class="rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800"><%= offer.type %></span></td>
            <td class="px-6 py-4 text-sm text-gray-900"><%= offer.type == "percentage" ? "#{offer.value}%" : number_to_currency(offer.value, unit: "€", format: "%u%n") %></td>
            <td class="px-6 py-4 text-sm font-mono text-gray-500"><%= offer.promo_code || "—" %></td>
            <td class="px-6 py-4">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-medium <%= offer.active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' %>">
                <%= offer.active ? "Active" : "Inactive" %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= offer.current_redemptions %><%= offer.max_redemptions ? "/#{offer.max_redemptions}" : "" %></td>
            <td class="px-6 py-4">
              <div class="flex gap-1">
                <%= link_to "Edit", edit_dashboard_offer_path(offer), class: "rounded-lg bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-200" %>
                <%= button_to "Delete", dashboard_offer_path(offer), method: :delete, class: "rounded-lg bg-red-50 px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-100",
                  data: { turbo_confirm: "Delete this offer?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-12 text-center text-gray-400">No offers yet</div>
  <% end %>
</div>
