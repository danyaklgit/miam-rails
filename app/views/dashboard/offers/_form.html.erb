<%= form_with model: [:dashboard, offer], class: "space-y-6" do |f| %>
  <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100 space-y-4">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
        <%= f.text_field :name, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
        <%= f.select :type, %w[percentage fixed happyHour bundle], {}, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Value</label>
        <%= f.number_field :value, step: 0.01, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Promo Code</label>
        <%= f.text_field :promo_code, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Max Redemptions</label>
        <%= f.number_field :max_redemptions, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Min Order Amount</label>
        <%= f.number_field :min_order_amount, step: 0.01, class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-gray-400" %>
      </div>
      <div class="flex items-center gap-2">
        <%= f.check_box :active, class: "h-4 w-4 rounded border-gray-300" %>
        <label class="text-sm font-medium text-gray-700">Active</label>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", dashboard_offers_path, class: "rounded-xl border border-gray-200 px-6 py-3 text-sm font-medium text-gray-600 hover:bg-gray-50" %>
  </div>
<% end %>
