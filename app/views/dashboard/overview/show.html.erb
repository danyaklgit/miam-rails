<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @restaurant.name %></h1>
  <p class="text-sm text-gray-500">miam.digital/<strong><%= @restaurant.slug %></strong></p>
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8">
  <%= link_to dashboard_analytics_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-50">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Today's Revenue</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= number_to_currency(@revenue_today, unit: "€", format: "%u%n") %></p>
      </div>
    </div>
  <% end %>

  <%= link_to dashboard_orders_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Today's Orders</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= @orders_today %></p>
      </div>
    </div>
  <% end %>

  <%= link_to dashboard_floor_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50">
        <svg class="h-6 w-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Active Tables</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= @active_sessions %></p>
      </div>
    </div>
  <% end %>

  <%= link_to dashboard_menu_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-50">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Menu Items</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= @restaurant.menu_items.count %></p>
      </div>
    </div>
  <% end %>

  <%= link_to dashboard_tables_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50">
        <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Tables</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= @restaurant.restaurant_tables.count %></p>
      </div>
    </div>
  <% end %>

  <%= link_to dashboard_reservations_path, class: "rounded-2xl bg-white p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow" do %>
    <div class="flex items-center gap-4">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50">
        <svg class="h-6 w-6 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Reservations Today</p>
        <p class="mt-1 text-2xl font-bold text-gray-900"><%= @reservations_today %></p>
      </div>
    </div>
  <% end %>
</div>

<%# Recent orders %>
<h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Orders</h2>
<div class="rounded-2xl bg-white shadow-sm border border-gray-100 overflow-hidden">
  <% if @recent_orders.any? %>
    <table class="w-full">
      <thead class="bg-gray-50 text-left text-xs font-medium uppercase text-gray-500">
        <tr>
          <th class="px-6 py-3">Order</th>
          <th class="px-6 py-3">Type</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3">Amount</th>
          <th class="px-6 py-3">Time</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @recent_orders.each do |order| %>
          <tr>
            <td class="px-6 py-4 text-sm font-medium text-gray-900">#<%= order.id.to_s[0, 8] %></td>
            <td class="px-6 py-4">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= order.type == 'dineIn' ? 'bg-purple-100 text-purple-800' : order.type == 'delivery' ? 'bg-blue-100 text-blue-800' : 'bg-amber-100 text-amber-800' %>">
                <%= order.type %>
              </span>
            </td>
            <td class="px-6 py-4">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= case order.status
                  when 'pending' then 'bg-gray-100 text-gray-800'
                  when 'confirmed' then 'bg-blue-100 text-blue-800'
                  when 'preparing' then 'bg-amber-100 text-amber-800'
                  when 'ready' then 'bg-green-100 text-green-800'
                  when 'completed' then 'bg-gray-100 text-gray-500'
                  else 'bg-red-100 text-red-800'
                end %>">
                <%= order.status %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= number_to_currency(order.total_amount, unit: "€", format: "%u%n") %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= time_ago_in_words(order.created_at) %> ago</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center text-gray-400">No orders yet</div>
  <% end %>
</div>
